{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["frame_id", "timestamp_ms", "vision_duration_ms", "objects"],
  "properties": {
    "frame_id": {"type": "integer"},
    "timestamp_ms": {"type": "integer"},
    "vision_duration_ms": {"type": "number"},
    "objects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["object_id","class","confidence","bbox","distance_m","pan_value"],
        "properties": {
          "object_id": {"type": "string"},
          "class": {"type": "string"},
          "confidence": {"type": "number"},
          "bbox": {
            "type": "object",
            "required": ["x_center_norm","y_center_norm","width_norm","height_norm"],
            "properties": {
              "x_center_norm": {"type": "number"},
              "y_center_norm": {"type": "number"},
              "width_norm": {"type": "number"},
              "height_norm": {"type": "number"}
            }
          },
          "distance_m": {"type": "number"},
          "pan_value": {"type": "number"},
          "velocity_mps": {"anyOf": [{"type": "number"}, {"type": "null"}]},
          "priority": {"type": "string"}
        }
      }
    }
  }
}
